const n1: number = 12345;
const n2: number = 67890;

/**
 * Función que suma dos números y devuelve el resultado
 * @param a Primer número
 * @param b Segundo número
 */
const calcularSuma = (a: number, b: number): number => {
    return a + b;
};

const total: number = calcularSuma(n1, n2);

console.log("---------------------------------------");
console.log(`La suma de ${n1} + ${n2} es igual a: ${total}`);
console.log("---------------------------------------");